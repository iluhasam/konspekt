# Токен телеграм-бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Модель OpenRouter для конспектов (дёшево и быстро)
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# База данных (Prisma). По умолчанию — локальный SQLite-файл.
DATABASE_URL="file:./dev.db"
